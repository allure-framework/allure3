{
  "name": "sandbox",
  "version": "3.13.1",
  "private": true,
  "description": "A package to test another Allure Report packages in action",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "Qameta Software",
  "type": "module",
  "scripts": {
    "g": "yarn allure generate --config=./allurerc.mjs",
    "o": "yarn allure open ./allure-report",
    "pret": "rimraf ./allure-results",
    "t": "yarn allure run -- vitest run",
    "test": "vitest run",
    "lint": "oxlint --import-plugin src test features stories",
    "lint:fix": "oxlint --import-plugin --fix src test features stories"
  },
  "devDependencies": {
    "@allurereport/plugin-awesome": "workspace:*",
    "@allurereport/plugin-csv": "workspace:*",
    "@allurereport/plugin-testops": "workspace:*",
    "@types/node": "^20",
    "@vitest/runner": "^4.0.18",
    "allure": "workspace:*",
    "allure-js-commons": "^3",
    "allure-vitest": "^3",
    "rimraf": "^6",
    "vite": "^8.0.9",
    "vitest": "^4.1.0"
  },
  "packageManager": "yarn@4.3.1"
}
