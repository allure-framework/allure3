{
  "name": "@allurereport/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Allure 3 Backend API with DDD architecture",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "clean": "rimraf ./dist",
    "predev": "yarn workspace @allurereport/web-commons run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run test/unit",
    "test:watch": "vitest test/unit",
    "test:coverage": "vitest run test/unit --coverage",
    "test:e2e": "NODE_OPTIONS='--import tsx' vitest run test/e2e --no-file-parallelism",
    "test:e2e:coverage": "NODE_OPTIONS='--import tsx' vitest run test/e2e --no-file-parallelism --coverage",
    "test:all": "yarn test && yarn test:e2e",
    "test:e2e:run": "tsx scripts/e2e-api.ts",
    "lint": "eslint ./src/**/*.{ts,tsx}",
    "lint:fix": "eslint --fix ./src/**/*.{ts,tsx}",
    "format": "prettier --write './src/**/*.{ts,tsx}'",
    "migration:generate": "typeorm migration:generate",
    "migration:run": "tsx src/scripts/run-migrations.ts",
    "migration:revert": "typeorm migration:revert",
    "db:setup": "docker-compose up -d postgres",
    "db:seed": "tsx src/infrastructure/persistence/seed.ts",
    "load-demo": "node scripts/upload_test_data.js",
    "load-demo-parent": "node scripts/load_demo_parent_launch.js",
    "load-demo-parent-empty-child": "node scripts/load_demo_parent_with_empty_child.js",
    "import-dir": "tsx scripts/import_from_directory.ts"
  },
  "dependencies": {
    "@allurereport/charts-api": "workspace:*",
    "@allurereport/core": "workspace:*",
    "@allurereport/core-api": "workspace:*",
    "@allurereport/plugin-api": "workspace:*",
    "@allurereport/reader": "workspace:*",
    "@allurereport/reader-api": "workspace:*",
    "@allurereport/service": "workspace:*",
    "@allurereport/web-commons": "workspace:*",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.17",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.2",
    "@types/multer": "^1.4.11",
    "@types/node": "^25.2.1",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
