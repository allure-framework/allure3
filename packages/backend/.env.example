# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=allure
DB_PASSWORD=allure
DB_DATABASE=allure_backend
DB_SSL=false

# JWT (если будет использоваться)
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=24h

# Attachment Storage
ATTACHMENT_STORAGE_TYPE=filesystem
ATTACHMENT_STORAGE_PATH=./storage/attachments
# Для S3:
# ATTACHMENT_STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=

# Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
