    "lint:fix": "oxlint --import-plugin --fix src test features stories"
  },
  "dependencies": {
    "lodash.debounce": "^4.0.8"
  },
  "devDependencies": {
    "@types/lodash.debounce": "^4.0.9",
    "@vitest/runner": "^2",
    "allure-js-commons": "^3",
    "allure-vitest": "^3",
    "rimraf": "^6",
    "tslib": "^2.7.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
